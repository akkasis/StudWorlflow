generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  role          String   @default("user")
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  lastSeenAt    DateTime?

  profile         Profile?
  reviews         Review[]
  sentMessages    Message[]            @relation("SentMessages")
  supportThread   SupportThread?
  supportMessages SupportMessage[]     @relation("SupportMessageSender")
  moderation      UserModerationState?
  verificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  favoriteTutors  FavoriteTutor[]
}

model Profile {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  name               String
  university         String
  course             Int
  description        String
  role               String   @default("student")
  priceFrom          Int
  averageGrade       Float?
  rating             Float    @default(0)
  avatarUrl          String?
  bannerUrl          String?
  availabilityFormats String[]  @default([])
  availabilityDays   String[]   @default([])
  availabilityTime   String?
  availabilityNote   String?
  createdAt          DateTime @default(now())

  user                       User           @relation(fields: [userId], references: [id])
  profileTags                ProfileTag[]
  reviews                    Review[]
  conversationsAsParticipantOne Conversation[] @relation("ConversationParticipantOne")
  conversationsAsParticipantTwo Conversation[] @relation("ConversationParticipantTwo")
  favoritedBy                FavoriteTutor[]
}

model FavoriteTutor {
  studentUserId Int
  tutorProfileId Int
  createdAt     DateTime @default(now())

  studentUser User    @relation(fields: [studentUserId], references: [id], onDelete: Cascade)
  tutorProfile Profile @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)

  @@id([studentUserId, tutorProfileId])
  @@index([tutorProfileId])
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique

  profiles ProfileTag[]
}

model ProfileTag {
  profileId Int
  tagId     Int

  profile Profile @relation(fields: [profileId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([profileId, tagId])
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int
  text       String
  createdAt  DateTime @default(now())

  userId     Int
  profileId  Int

  user        User                   @relation(fields: [userId], references: [id])
  profile     Profile                @relation(fields: [profileId], references: [id])
  moderation  ReviewModerationState?
}

model Conversation {
  id                      String    @id
  participantOneProfileId Int
  participantTwoProfileId Int
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  participantOne Profile   @relation("ConversationParticipantOne", fields: [participantOneProfileId], references: [id], onDelete: Cascade)
  participantTwo Profile   @relation("ConversationParticipantTwo", fields: [participantTwoProfileId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@unique([participantOneProfileId, participantTwoProfileId])
}

model Message {
  id                   String   @id
  conversationId       String
  senderUserId         Int
  text                 String
  createdAt            DateTime @default(now())
  readByParticipantOne Boolean  @default(false)
  readByParticipantTwo Boolean  @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model SupportThread {
  userId     Int      @id
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]
}

model SupportMessage {
  id           String   @id
  threadUserId Int
  senderUserId Int
  text         String
  createdAt    DateTime @default(now())

  thread  SupportThread @relation(fields: [threadUserId], references: [userId], onDelete: Cascade)
  sender  User          @relation("SupportMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([threadUserId, createdAt])
}

model UserModerationState {
  userId         Int       @id
  tutorVerified  Boolean   @default(false)
  banPermanent   Boolean   @default(false)
  banUntil       DateTime?
  banReason      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReviewModerationState {
  reviewId    Int     @id
  verified    Boolean @default(false)

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String   @id
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
